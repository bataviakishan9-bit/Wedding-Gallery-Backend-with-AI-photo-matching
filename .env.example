PORT=3000
NODE_ENV=development

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Service Account JSON (paste entire JSON as single line or multi-line)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# PostgreSQL (will be set by Render automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/wedding_gallery
